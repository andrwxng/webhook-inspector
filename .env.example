# Copy to .env for local development. Never commit real values.

# Backend HTTP port
PORT=3000

# Postgres (matches docker-compose.yml defaults)
DATABASE_URL=postgres://webhook:webhook@localhost:5432/webhook_inspector

# Redis (matches docker-compose.yml defaults). Required in production for
# ingest rate limiting; if unset there, rate limiting is disabled (warns).
REDIS_URL=redis://localhost:6379

# Ingest protections (defaults shown; all optional)
#INGEST_BODY_LIMIT_BYTES=1048576
#INGEST_RATE_LIMIT=120
#INGEST_RATE_WINDOW_SEC=60

# Retention (defaults shown; all optional)
#RETENTION_MAX_PER_ENDPOINT=500
#RETENTION_MAX_AGE_DAYS=7
#CLEANUP_INTERVAL_SEC=600

# Replay / forwarding (defaults shown; all optional)
#REPLAY_TIMEOUT_MS=10000
#REPLAY_MAX_RESPONSE_BYTES=65536
# Set to 1 ONLY for local dev, to allow replaying to localhost/private IPs.
#REPLAY_ALLOW_PRIVATE=1
